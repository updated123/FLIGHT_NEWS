# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Candidate identity
CANDIDATE_NAME=Utsav Kumar Patel
CANDIDATE_EMAIL=your.email@example.com
GITHUB_USERNAME=updated123
TIMEZONE=Asia/Kolkata
MEETING_DURATION_MINUTES=30

# Public deployment URL (Render/Railway/Fly)
PUBLIC_BASE_URL=https://your-app.onrender.com

# Vapi voice agent
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=change-me-to-random-string

# Calendar — choose ONE provider

# Option A: Google Calendar (service account JSON path or inline JSON)
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option B: Cal.com
CAL_COM_API_KEY=
CAL_COM_EVENT_TYPE_ID=

# Optional: higher GitHub API rate limits during ingestion
GITHUB_TOKEN=
